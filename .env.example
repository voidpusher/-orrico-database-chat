# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# Public URL of your deployment (no trailing slash)
APP_BASE_URL=https://yourdomain.com

# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=replace-with-64-char-hex-string

# Comma-separated allowed CORS origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── App database (PostgreSQL required in production) ──────────────────────────
DATABASE_URL=postgresql://orrico:yourpassword@db:5432/orrico
PGSSL=disable

# Used by docker-compose for the Postgres container password
POSTGRES_PASSWORD=yourpassword

# ── Session & token TTLs ──────────────────────────────────────────────────────
SESSION_TTL_HOURS=720
PASSWORD_RESET_TTL_HOURS=2
EMAIL_VERIFICATION_TTL_HOURS=24

# ── Data directory (ignored in Docker; volume is used instead) ────────────────
APP_DATA_DIRECTORY=server/data

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Set EMAIL_AUTH_OPTIONAL=true to skip email verification (not recommended for prod)
EMAIL_AUTH_OPTIONAL=false
EMAIL_PROVIDER=resend
EMAIL_FROM=hello@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Stripe billing ────────────────────────────────────────────────────────────
# Leave all blank to run without billing (all users get the Free plan)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Create these prices in your Stripe dashboard (recurring / monthly)
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ── AI chat (optional) ────────────────────────────────────────────────────────
# Leave blank → local RAG engine (no API cost, works offline)
# Set → Claude LLM mode for highest-quality natural language answers
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
